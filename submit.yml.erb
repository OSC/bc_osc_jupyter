<%-

  base_slurm_args = ["--nodes", "1", "--ntasks-per-node", "#{num_cores.to_i}"]

  # Remove cluster tag, e.g. pitzer-gpu-exp to gpu-exp
  partition = global_node_type.split('-').drop(1).join('-')

  slurm_args = base_slurm_args + ["--partition", partition]

-%>
<% if global_cluster =~ /pitzer|ascend|cardinal/ -%>
---
batch_connect:
  template: "basic"
  conn_params:
    - jupyter_api
script:
  <%- if gpus.to_i > 0 -%>
  gpus_per_node: <%= gpus %>
  <%- end %>
  native:
  <%- slurm_args.each do |arg| %>
  - "<%= arg %>"
  <%- end %>
<% end -%>
